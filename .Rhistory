url <- "https://api.trademe.co.nz/v1/Search/Property/Residential.json?region=15"
oauth_consumer_key <- 'B8DF64DF234AB9A30768DA104D6FEEBB'
oauth_token <- '985764EFC8F0102B9A7A917334B6872A'
oauth_signature_method <- 'PLAINTEXT'
oauth_signature <- '9345B0056DE1E81BDA9617D35996AC82%26158EAF421B7A2597F4242D757A3F7FDF'
header <- paste('OAuth oauth_consumer_key=', oauth_consumer_key,
',oauth_token=', oauth_token,
',oauth_signature_method=', oauth_signature_method,
',oauth_signature=', oauth_signature,
sep = '')
## Scraping loop
rows <- 500
stop <- 0
i <- 1
dat <- list()
while(stop < 1) {
url_page <- paste0(url,'&rows=',rows,'&page=',i)
tmp <- GET(url_page, add_headers(Authorization = header))
dat[[i]] <- tmp
stop <- if(ceiling(fromJSON(content(tmp, as='text'))$TotalCount/rows) == i){1}else{0}
i <- i+1
}
rm(i, stop, rows, url_page)
## melt paginated data together
df <- bind_rows(lapply(dat, function(x) { fromJSON(content(x, as='text'))$List %>% as.data.frame() }))
## rm(dat)
df
df$GeographicLocation$Longitude
df
df$lon <- df$GeographicLocation$Longitude
df$lat <- df$GeographicLocation$Latitude
df_sf <- st_as_sf(x = df, coords = c('Longitude', 'Latitude'), crs = 4326)
library(sf)
df_sf <- st_as_sf(x = df, coords = c('Longitude', 'Latitude'), crs = 4326)
df_sf <- st_as_sf(x = df, coords = c('lon', 'lat'), crs = 4326)
df_sf
